{
  "manifest_version": 3,
  "name": "USPscraper",
  "version": "1.0.0",
  "description": "Baixa materiais dos seus cursos em andamento no edisciplinas.usp.br.",
  "permissions": [
    "cookies",
    "downloads"
  ],
  "host_permissions": [
    "https://edisciplinas.usp.br/*",
    "https://uspdigital.usp.br/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "uspscraper@usp",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
