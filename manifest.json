{
  "manifest_version": 3,
  "name": "edisciplinas Downloader",
  "version": "1.0.0",
  "description": "Baixa materiais dos seus cursos em andamento no edisciplinas USP.",
  "permissions": [
    "cookies",
    "downloads"
  ],
  "host_permissions": [
    "https://edisciplinas.usp.br/*",
    "https://uspdigital.usp.br/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["vendor/jszip.min.js", "background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "edisciplinas-downloader@usp",
      "strict_min_version": "109.0"
    }
  }
}
